---
const navItems = [
  { label: "About", href: "/#about" },
  { label: "Experience", href: "/#experience" },
  { label: "Skills", href: "/#skills" },
  { label: "Projects", href: "/#projects" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/#contact" },
];
---

<header
  id="site-header"
  transition:persist
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="nav-logo text-lg font-bold text-white dark:text-white transition-colors">
        Daniel Zhang
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Primary" class="hidden md:flex items-center gap-1">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="nav-link px-3 py-2 text-sm font-medium text-white/90 hover:text-white dark:text-slate-300 dark:hover:text-white transition-colors rounded-lg hover:bg-white/10 dark:hover:bg-white/10"
            >
              {item.label}
            </a>
          ))
        }
        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          class="nav-btn ml-2 p-2 rounded-lg text-white/90 hover:text-white dark:text-slate-300 dark:hover:text-white hover:bg-white/10 dark:hover:bg-white/10 transition-colors"
          aria-label="Toggle theme"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg
            class="w-5 h-5 hidden dark:block"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <path
              d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
            ></path>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg
            class="w-5 h-5 block dark:hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </nav>

      <!-- Mobile Menu Button -->
      <div class="flex items-center gap-2 md:hidden">
        <button
          id="theme-toggle-mobile"
          class="nav-btn p-2 rounded-lg text-white/90 dark:text-slate-300 transition-colors"
          aria-label="Toggle theme"
        >
          <svg
            class="w-5 h-5 hidden dark:block"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <path
              d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
            ></path>
          </svg>
          <svg
            class="w-5 h-5 block dark:hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
        <button
          id="mobile-menu-btn"
          class="nav-btn p-2 rounded-lg text-white/90 dark:text-slate-300 transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-white/10 dark:border-slate-700"
    >
      <nav aria-label="Mobile" class="flex flex-col gap-1 pt-3">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="mobile-nav-link nav-link px-3 py-2.5 text-sm font-medium text-white/90 dark:text-slate-300 hover:bg-white/10 dark:hover:bg-white/10 rounded-lg transition-colors"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<style>
  @reference "tailwindcss";

  /* Scrolled header background */
  :global(#site-header.scrolled) {
    @apply bg-white/95 dark:bg-slate-950/95 backdrop-blur-md shadow-sm;
  }

  /* Scrolled: logo */
  :global(#site-header.scrolled) .nav-logo {
    @apply text-slate-900 dark:text-white;
  }

  /* Scrolled: nav links & buttons base */
  :global(#site-header.scrolled) .nav-link,
  :global(#site-header.scrolled) .nav-btn {
    @apply text-slate-600 dark:text-slate-400;
  }

  /* Scrolled: nav link hover */
  :global(#site-header.scrolled) .nav-link:hover,
  :global(#site-header.scrolled) .nav-btn:hover {
    @apply text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-800;
  }

  /* Scrolled: active nav link (ScrollSpy) */
  :global(#site-header.scrolled) .nav-link.active {
    color: var(--color-primary-600);
    background-color: var(--color-primary-50);
  }
  :global(.dark #site-header.scrolled) .nav-link.active {
    color: var(--color-primary-400);
    background-color: color-mix(in srgb, var(--color-primary-900) 30%, transparent);
  }

  /* Non-scrolled: active nav link */
  :global(#site-header:not(.scrolled)) .nav-link.active {
    @apply text-white bg-white/20;
  }

  /* Scrolled: mobile menu border */
  :global(#site-header.scrolled) #mobile-menu {
    @apply border-slate-200 dark:border-slate-700;
  }
</style>

<script>
  // The header element is transition:persist'd, so this script's one-time
  // wiring (sticky observer, theme toggle, mobile menu listeners) stays
  // valid across client-side navigations. Only ScrollSpy needs to retarget
  // the sections of the newly-loaded page on each astro:page-load.

  type SpyState = { observer: IntersectionObserver | null };
  const spyState: SpyState = { observer: null };

  function setupHeaderOnce() {
    const header = document.getElementById("site-header");
    if (!header) return;

    // Sticky sentinel — placed once.
    if (!document.getElementById("site-header-sentinel")) {
      const sentinel = document.createElement("div");
      sentinel.id = "site-header-sentinel";
      sentinel.setAttribute("aria-hidden", "true");
      sentinel.style.cssText =
        "position:absolute;top:80px;left:0;width:1px;height:1px;pointer-events:none;";
      document.body.prepend(sentinel);

      new IntersectionObserver(
        ([entry]) => {
          header.classList.toggle("scrolled", !entry.isIntersecting);
        },
        { threshold: 0 },
      ).observe(sentinel);
    }

    const menuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const setMobileMenu = (open: boolean) => {
      if (!mobileMenu || !menuBtn) return;
      mobileMenu.classList.toggle("hidden", !open);
      menuBtn.setAttribute("aria-expanded", String(open));
    };

    menuBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      setMobileMenu(mobileMenu?.classList.contains("hidden") ?? true);
    });
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => setMobileMenu(false));
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !mobileMenu?.classList.contains("hidden")) {
        setMobileMenu(false);
        menuBtn?.focus();
      }
    });
    document.addEventListener("click", (e) => {
      if (mobileMenu?.classList.contains("hidden")) return;
      if (!header.contains(e.target as Node)) setMobileMenu(false);
    });

    const toggleTheme = () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };
    document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
    document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);
  }

  function setupScrollSpy() {
    spyState.observer?.disconnect();
    spyState.observer = null;

    const sections = document.querySelectorAll<HTMLElement>("section[id]");
    const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
    if (sections.length === 0 || navLinks.length === 0) {
      navLinks.forEach((link) => link.classList.remove("active"));
      return;
    }

    const linkByHref = new Map<string, HTMLAnchorElement>();
    navLinks.forEach((link) => {
      const href = link.getAttribute("href");
      if (href) linkByHref.set(href, link);
    });

    const intersecting = new Set<string>();
    const setActive = (id: string | null) => {
      navLinks.forEach((link) => link.classList.remove("active"));
      if (!id) return;
      linkByHref.get(`/#${id}`)?.classList.add("active");
    };

    spyState.observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) intersecting.add(e.target.id);
          else intersecting.delete(e.target.id);
        }
        let active: string | null = null;
        for (const section of sections) {
          if (intersecting.has(section.id)) {
            active = section.id;
            break;
          }
        }
        setActive(active);
      },
      { rootMargin: "-25% 0px -60% 0px", threshold: 0 },
    );
    sections.forEach((s) => spyState.observer!.observe(s));
  }

  // Run once for the initial bundle load; reattach ScrollSpy on every
  // client-side navigation.
  setupHeaderOnce();
  setupScrollSpy();
  document.addEventListener("astro:page-load", setupScrollSpy);
</script>
