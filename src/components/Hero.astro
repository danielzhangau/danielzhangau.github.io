---
import Icon from "@/components/Icon.astro";
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-slate-900"
>
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src="/img/code.webp"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-30"
      width="2400"
      height="1600"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/80 to-slate-900">
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div class="animate-fade-in-up">
      <div class="flex items-center justify-center gap-4 mb-6">
        <img
          src="/img/emoji.webp"
          alt="Daniel's Emoji"
          width="80"
          height="80"
          class="w-16 h-16 sm:w-20 sm:h-20"
          loading="eager"
          decoding="async"
        />
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 tracking-tight">
        Bosheng (Daniel) Zhang
      </h1>
      <p
        class="text-lg sm:text-xl text-slate-300 mb-4 font-medium animate-fade-in-up animate-delay-100"
      >
        AI/ML Engineer · Solution Architect
      </p>
      <p
        class="text-base sm:text-lg text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in-up animate-delay-200"
      >
        Designing and delivering end-to-end AI systems — from computer vision pipelines to
        LLM-powered platforms. Specialized in AI agents, RAG, and production AI solutions.
      </p>

      <!-- CTA Buttons -->
      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12 animate-fade-in-up animate-delay-300"
      >
        <a
          href="/#projects"
          class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-all hover:shadow-lg hover:shadow-primary-600/25"
        >
          View Projects
          <Icon name="chevron-down" class="w-4 h-4 ml-2" />
        </a>
        <a
          href="/#contact"
          class="inline-flex items-center px-6 py-3 border border-white/20 hover:border-white/40 text-white font-medium rounded-lg transition-all hover:bg-white/5"
        >
          Get in Touch
        </a>
      </div>

      <!-- Social Links -->
      <div class="flex items-center justify-center gap-5 animate-fade-in-up animate-delay-400">
        <a
          href="https://github.com/danielzhangau"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-11 h-11 rounded text-slate-400 hover:text-white transition-colors"
          aria-label="GitHub"
        >
          <Icon name="github" class="w-6 h-6" />
        </a>
        <a
          href="https://www.linkedin.com/in/bosheng-zhang-7b7036149/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-11 h-11 rounded text-slate-400 hover:text-white transition-colors"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin" class="w-6 h-6" />
        </a>
        <a
          href="mailto:ddaniel.zhang0413@gmail.com"
          class="inline-flex items-center justify-center w-11 h-11 rounded text-slate-400 hover:text-white transition-colors"
          aria-label="Email"
        >
          <Icon name="mail" class="w-6 h-6" />
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <svg
      class="w-6 h-6 text-slate-500"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
