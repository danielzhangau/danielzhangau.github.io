---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

{
  posts.length > 0 && (
    <section id="blog" class="py-20 sm:py-28 bg-white dark:bg-slate-950">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4 text-center">
          Blog
        </h2>
        <p class="text-slate-500 dark:text-slate-400 text-center mb-12">
          Thoughts on AI, engineering, and building things.
        </p>

        <div class="space-y-6">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block bg-slate-50 dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm hover:border-primary-300 dark:hover:border-primary-700 transition-all hover:shadow-md"
            >
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                  {post.data.title}
                </h3>
                <time class="text-sm text-slate-400 dark:text-slate-500 shrink-0">
                  {formatDate(post.data.pubDate)}
                </time>
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-3">
                {post.data.description}
              </p>
              {post.data.tags && (
                <div class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag: string) => (
                    <span class="inline-block px-2 py-0.5 text-xs font-medium bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>

        <div class="text-center mt-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors"
          >
            Read all posts
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )
}
