---
interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  featured?: boolean;
  image?: string;
}

const { title, description, tags, slug, featured = false, image } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class:list={[
    "group block bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden transition-all duration-300 hover:shadow-lg hover:border-primary-300 dark:hover:border-primary-700 hover:-translate-y-1",
    featured && "sm:col-span-2 lg:col-span-1",
  ]}
>
  {
    image && (
      <div class="aspect-video bg-white overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )
  }
  {
    !image && (
      <div class="aspect-video bg-gradient-to-br from-primary-50 to-primary-100 dark:from-primary-950 dark:to-slate-900 flex items-center justify-center">
        <svg
          class="w-12 h-12 text-primary-300 dark:text-primary-700"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1"
        >
          <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
    )
  }

  <div class="p-5">
    <h3
      class="text-lg font-bold text-slate-900 dark:text-white mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors"
    >
      {title}
    </h3>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {
        tags
          .slice(0, 4)
          .map((tag) => (
            <span class="inline-block px-2 py-0.5 text-xs font-medium bg-primary-50 dark:bg-slate-700 text-primary-700 dark:text-slate-200 rounded">
              {tag}
            </span>
          ))
      }
      {
        tags.length > 4 && (
          <span class="inline-block px-2 py-0.5 text-xs font-medium text-slate-400 dark:text-slate-500">
            +{tags.length - 4}
          </span>
        )
      }
    </div>
  </div>
</a>
