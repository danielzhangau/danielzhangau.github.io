---
import Icon from "@/components/Icon.astro";
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500 dark:text-slate-400">
        &copy; {currentYear} Bosheng (Daniel) Zhang. Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-600 dark:text-primary-400 hover:underline"
        >
          Astro
        </a>
      </p>
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/danielzhangau"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors"
          aria-label="GitHub"
        >
          <Icon name="github" />
        </a>
        <a
          href="https://www.linkedin.com/in/bosheng-zhang-7b7036149/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin" />
        </a>
      </div>
    </div>
  </div>
</footer>
