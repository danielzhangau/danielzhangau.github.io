---
import Icon from "@/components/Icon.astro";
---

<section id="contact" class="py-20 sm:py-28 bg-slate-50 dark:bg-slate-900">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4">
      Let's Connect
    </h2>
    <p class="text-slate-500 dark:text-slate-400 mb-10 leading-relaxed">
      I'm always open to discussing AI/ML projects, freelance development work, or just connecting
      with fellow engineers. Feel free to reach out!
    </p>

    <!-- Email -->
    <a
      href="mailto:ddaniel.zhang0413@gmail.com"
      class="inline-flex items-center gap-3 px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-all hover:shadow-lg hover:shadow-primary-600/25 mb-10"
    >
      <Icon name="mail" />
      ddaniel.zhang0413@gmail.com
    </a>

    <!-- Social Links -->
    <div class="flex items-center justify-center gap-4">
      <a
        href="https://github.com/danielzhangau"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="flex items-center gap-2 px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:border-slate-300 dark:hover:border-slate-600 hover:shadow-sm transition-all"
      >
        <Icon name="github" />
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/bosheng-zhang-7b7036149/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="flex items-center gap-2 px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:border-slate-300 dark:hover:border-slate-600 hover:shadow-sm transition-all"
      >
        <Icon name="linkedin" />
        LinkedIn
      </a>
    </div>
  </div>
</section>
