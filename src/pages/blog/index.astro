---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@/utils/format";
import { tagToSlug } from "@/utils/slug";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog | Bosheng Zhang"
  description="Thoughts on AI/ML engineering, production systems, and technical deep-dives."
>
  <div class="pt-24 pb-20 bg-white dark:bg-slate-950 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <!-- Header -->
      <div class="mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-1 text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 mb-6 transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Home
        </a>
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-4">Blog</h1>
        <p class="text-lg text-slate-500 dark:text-slate-400">
          Thoughts on AI/ML engineering, production systems, and building things.
        </p>
      </div>

      <!-- Search -->
      <div class="mb-10">
        <label for="blog-search" class="sr-only">Search posts</label>
        <div class="relative">
          <span
            class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-500 dark:text-slate-400"
            aria-hidden="true"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 21l-4.35-4.35M11 18a7 7 0 1 1 0-14 7 7 0 0 1 0 14z"></path>
            </svg>
          </span>
          <input
            id="blog-search"
            type="search"
            autocomplete="off"
            placeholder="Search posts by title, description, or tag…"
            class="w-full pl-10 pr-4 py-2.5 text-sm rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 placeholder:text-slate-500 dark:placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
          />
        </div>
        <p
          id="blog-search-status"
          class="mt-2 text-xs text-slate-500 dark:text-slate-400"
          aria-live="polite"
        >
        </p>
      </div>

      <!-- Posts -->
      {
        posts.length === 0 && (
          <p class="text-slate-500 dark:text-slate-400 text-center py-12">
            No posts yet. Check back soon!
          </p>
        )
      }

      <div id="blog-list" class="space-y-8">
        {
          posts.map((post) => {
            const haystack = [post.data.title, post.data.description, ...(post.data.tags ?? [])]
              .join(" ")
              .toLowerCase();
            return (
              <article data-search={haystack}>
                <a href={`/blog/${post.id}`} class="group block">
                  <time class="text-sm text-slate-500 dark:text-slate-400">
                    {formatDate(post.data.pubDate)}
                  </time>
                  <h2 class="text-xl font-bold text-slate-900 dark:text-white mt-1 mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-3">
                    {post.data.description}
                  </p>
                </a>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-2">
                    {post.data.tags.map((tag: string) => (
                      <a
                        href={`/blog/tags/${tagToSlug(tag)}`}
                        class="inline-block px-2 py-0.5 text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded hover:bg-primary-50 dark:hover:bg-primary-950 hover:text-primary-700 dark:hover:text-primary-300 transition-colors"
                      >
                        {tag}
                      </a>
                    ))}
                  </div>
                )}
              </article>
            );
          })
        }
      </div>

      <p id="blog-empty" class="hidden text-slate-500 dark:text-slate-400 text-center py-12">
        No posts match your search.
      </p>
    </div>
  </div>

  <script>
    const input = document.getElementById("blog-search") as HTMLInputElement | null;
    const list = document.getElementById("blog-list");
    const status = document.getElementById("blog-search-status");
    const empty = document.getElementById("blog-empty");
    if (input && list && status && empty) {
      const articles = Array.from(list.querySelectorAll<HTMLElement>("article[data-search]"));
      const total = articles.length;

      const update = () => {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        for (const a of articles) {
          const match = q === "" || (a.dataset.search ?? "").includes(q);
          a.hidden = !match;
          if (match) visible++;
        }
        empty.hidden = visible !== 0;
        empty.classList.toggle("hidden", visible !== 0);
        status.textContent =
          q === "" ? "" : `${visible} of ${total} ${total === 1 ? "post" : "posts"} match`;
      };

      input.addEventListener("input", update);
      input.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          input.value = "";
          update();
          input.blur();
        }
      });
    }
  </script>
</BaseLayout>
