---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}

const project = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={`${project.data.title} | Bosheng Zhang`}
  description={project.data.description}
  image={project.data.image}
>
  <article class="pt-24 pb-20 bg-white dark:bg-slate-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <!-- Navigation -->
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 mb-8 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M15 19l-7-7 7-7"></path>
        </svg>
        All Projects
      </a>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          <span
            class:list={[
              "inline-block px-2.5 py-0.5 text-xs font-semibold rounded-full uppercase tracking-wider",
              project.data.category === "production"
                ? "bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-300"
                : "bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300",
            ]}
          >
            {project.data.category === "production" ? "Production" : "Academic"}
          </span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">
          {project.data.title}
        </h1>
        <p class="text-lg text-slate-500 dark:text-slate-400 leading-relaxed">
          {project.data.description}
        </p>

        <!-- Tags & Links -->
        <div class="mt-6 flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex flex-wrap gap-1.5">
            {project.data.tags.map((tag: string) => (
              <span class="inline-block px-2.5 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded-md">
                {tag}
              </span>
            ))}
          </div>
          {project.data.github && (
            <a
              href={project.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-slate-900 dark:bg-slate-700 text-white text-sm font-medium rounded-lg hover:bg-slate-800 dark:hover:bg-slate-600 transition-colors shrink-0"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
              </svg>
              View Source
            </a>
          )}
        </div>
      </header>

      <!-- Cover Image -->
      {project.data.image && (
        <div class="mb-10 rounded-xl overflow-hidden shadow-lg bg-white">
          <img
            src={project.data.image}
            alt={project.data.title}
            class="w-full"
            loading="lazy"
          />
        </div>
      )}

      <!-- Content -->
      <div class="prose max-w-none">
        <Content />
      </div>

      <!-- Back link -->
      <div class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to all projects
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
