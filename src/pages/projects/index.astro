---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sorted = projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const production = sorted.filter((p) => p.data.category === "production");
const academic = sorted.filter((p) => p.data.category === "academic");
---

<BaseLayout title="Projects | Bosheng Zhang" description="AI/ML projects and research work by Bosheng (Daniel) Zhang.">
  <div class="pt-24 pb-20 bg-white dark:bg-slate-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- Header -->
      <div class="mb-16">
        <a
          href="/"
          class="inline-flex items-center gap-1 text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 mb-6 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Home
        </a>
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-4">
          All Projects
        </h1>
        <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl">
          A collection of production AI/ML systems and academic research projects.
        </p>
      </div>

      <!-- Production Projects -->
      {production.length > 0 && (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">
            Production Systems
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {production.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                slug={project.id}
                image={project.data.image}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Academic Projects -->
      {academic.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">
            Academic & Research
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {academic.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                slug={project.id}
                image={project.data.image}
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
