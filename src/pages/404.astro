---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 — Page Not Found | Bosheng Zhang"
  description="The page you're looking for doesn't exist."
>
  <section
    class="min-h-screen flex items-center justify-center bg-white dark:bg-slate-950 px-4 sm:px-6 py-24"
  >
    <div class="max-w-xl mx-auto text-center">
      <p
        class="text-sm font-semibold text-primary-600 dark:text-primary-400 tracking-wider uppercase"
      >
        Error 404
      </p>
      <h1
        class="mt-3 text-5xl sm:text-6xl font-extrabold text-slate-900 dark:text-white tracking-tight"
      >
        Page not found
      </h1>
      <p class="mt-6 text-base sm:text-lg text-slate-500 dark:text-slate-400 leading-relaxed">
        The page you're looking for doesn't exist, was moved, or never existed in the first place.
        Try one of the links below.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-all hover:shadow-lg hover:shadow-primary-600/25"
        >
          Back to Home
        </a>
        <a
          href="/blog"
          class="inline-flex items-center px-6 py-3 border border-slate-300 dark:border-slate-700 hover:border-slate-400 dark:hover:border-slate-600 text-slate-700 dark:text-slate-300 font-medium rounded-lg transition-all"
        >
          Read the Blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
