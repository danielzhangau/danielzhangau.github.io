---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import "@/styles/fonts.css";
import "@/styles/global.css";
import inter400Url from "@fontsource/inter/files/inter-latin-400-normal.woff2?url";
import inter700Url from "@fontsource/inter/files/inter-latin-700-normal.woff2?url";

interface ArticleData {
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: ArticleData;
}

const {
  title = "Bosheng (Daniel) Zhang | AI/ML Engineer & Solution Architect",
  description = "AI engineer with 4+ years of experience designing and delivering end-to-end AI systems. Specialized in computer vision, LLM agents, RAG, and production AI solutions.",
  image = "/img/portfolio-picture.webp",
  article,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
const ogType = article ? "article" : "website";

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Bosheng Zhang",
  alternateName: "Daniel Zhang",
  url: "https://danielzhangau.github.io/",
  image: "https://danielzhangau.github.io/img/portfolio-picture.webp",
  jobTitle: "AI/ML Engineer & Solution Architect",
  alumniOf: {
    "@type": "EducationalOrganization",
    name: "University of Queensland",
  },
  knowsAbout: [
    "Artificial Intelligence",
    "Solution Architecture",
    "AI Agents",
    "Large Language Models",
    "RAG",
    "Computer Vision",
    "PyTorch",
    "Google Cloud Platform",
  ],
  sameAs: [
    "https://github.com/danielzhangau",
    "https://www.linkedin.com/in/bosheng-zhang-7b7036149/",
  ],
};

const articleJsonLd = article
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      image: ogImageURL.toString(),
      datePublished: article.pubDate.toISOString(),
      ...(article.updatedDate && { dateModified: article.updatedDate.toISOString() }),
      author: {
        "@type": "Person",
        name: "Bosheng Zhang",
        url: "https://danielzhangau.github.io/",
      },
      publisher: {
        "@type": "Person",
        name: "Bosheng Zhang",
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalURL.toString(),
      },
      ...(article.tags && article.tags.length > 0 && { keywords: article.tags.join(", ") }),
    }
  : null;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="all,follow" />
    <meta name="author" content="Bosheng (Daniel) Zhang" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="AI Engineer, Solution Architect, AI Agents, LLM, RAG, Computer Vision, PyTorch, Google Cloud Platform, Brisbane, Australia, Machine Learning, MLOps"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Bosheng Zhang Portfolio" />
    <meta property="og:locale" content="en_US" />
    {
      article && (
        <>
          <meta property="article:published_time" content={article.pubDate.toISOString()} />
          {article.updatedDate && (
            <meta property="article:modified_time" content={article.updatedDate.toISOString()} />
          )}
          {article.tags?.map((tag) => (
            <meta property="article:tag" content={tag} />
          ))}
        </>
      )
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />

    <!-- Preload critical fonts to reduce render-blocking on first paint -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href={inter400Url} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={inter700Url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Bosheng Zhang | Blog"
      href={new URL("rss.xml", Astro.site)}
    />

    <title>{title}</title>
    <ClientRouter />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd ?? personJsonLd)} />
    {articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />}

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        if (
          stored === "dark" ||
          (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
